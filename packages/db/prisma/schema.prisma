generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─── ENUMS ───────────────────────────────────────────────────────

enum ProductStatus {
  AVAILABLE
  SOLD
  RESERVED
  NOT_SURE
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  PRO
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum CollectionStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum EnquiryStatus {
  NEW
  SEEN
  REPLIED
  CLOSED
}

enum TryOnStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum MeasurementSource {
  PHOTO // derived from front+back photo via MediaPipe Pose
  MANUAL // entered directly via inch-tape
}

enum Gender {
  MALE
  FEMALE
}

enum SizeChartCategory {
  UPPER // Kurtas, Tops, Anarkalis, Dresses — bust/waist/hip
  LOWER // Pants, Palazzos, Skirts — waist/hip/length
}

// ─── INTERNAL TEAM (Kanchuki admin/marketing/support, not retailer-side) ──

enum TeamRole {
  SUPER_ADMIN
  MARKETING_MANAGER
  MARKETING_AGENT
  SUPPORT_MANAGER
  SUPPORT_AGENT
}

enum TerritoryLevel {
  STATE
  CITY
  ZONE
}

enum TicketStatus {
  OPEN
  ASSIGNED
  RESOLVED
  CLOSED
}

// ─── QUOTA & LIMITS (F-010) ──────────────────────────────────────

enum QuotaResourceType {
  PRODUCT_UPLOAD
  AI_TAGGING_CALL
  TRY_ON
  IMAGE_CROP
  BG_REMOVAL
  API_REQUEST
}

enum QuotaPeriod {
  DAY
  MONTH
  LIFETIME
}

enum QuotaAddonStatus {
  PENDING
  COMPLETED
  FAILED
}

// ─── RETAILERS ───────────────────────────────────────────────────

model Retailer {
  id           String  @id @default(cuid())
  auth_user_id String  @unique // Supabase auth.users.id
  phone        String  @unique
  shop_name    String
  owner_name   String?
  city         String
  state        String?
  gstin        String?

  // WhatsApp business number — nullable, falls back to `phone` if unset
  // Allows retailers to use a separate business number for collection link
  // enquiries and remote try-on (PRO-REQUIREMENTS.md F-009 §4).
  whatsapp_number String?

  // Full address (city/state above are pre-existing, kept for search/display)
  // address_line1 is enforced as required at the API/UI layer (F-009 profile
  // edit) — kept nullable in the DB since older rows predate the requirement.
  address_line1 String?
  address_line2 String?
  pincode       String?

  // Store branding — optional
  logo_url    String?
  logo_r2_key String?

  // KYC verification (F-009) — GST certificate + Aadhar front/back for identity proof
  kyc_status              KycStatus @default(NOT_SUBMITTED)
  kyc_gst_url             String?
  kyc_gst_r2_key          String?
  kyc_aadhar_front_url    String?
  kyc_aadhar_front_r2_key String?
  kyc_aadhar_back_url     String?
  kyc_aadhar_back_r2_key  String?
  kyc_submitted_at        DateTime?
  kyc_reviewed_at         DateTime?
  kyc_rejection_reason    String?

  // Meta WhatsApp Business API — retailer's own credentials, bring-your-own.
  // When set, collection bulk-send uses this instead of the one-by-one wa.me
  // flow. Requires a pre-approved message template in the retailer's Meta
  // Business Manager (single body variable — see collections.ts bulk-send).
  whatsapp_api_phone_number_id String?
  whatsapp_api_access_token    String?
  whatsapp_api_template_name   String?
  whatsapp_api_template_lang   String?
  whatsapp_api_configured_at   DateTime?

  categories String[] // ["suits", "sarees", "kurtis"]

  // Public QR profile — visitors scan a QR encoding /store/{public_slug},
  // pass the contact gate, then land on this collection as the storefront.
  public_slug              String? @unique
  storefront_collection_id String? // FK to Collection.id, no Prisma relation (loose pointer, same convention as Product.source_id)

  // Internal team attribution (Section 10, PRO-REQUIREMENTS.md) — nullable,
  // only set for retailers onboarded/derived through the internal team flow.
  territory_id     String?
  onboarded_by_id  String? // TeamMember.id — marketing agent who signed them up
  support_owner_id String? // TeamMember.id — current support point of contact

  // Subscription
  plan            SubscriptionPlan   @default(STARTER)
  plan_status     SubscriptionStatus @default(TRIAL)
  trial_ends_at   DateTime?
  plan_expires_at DateTime?

  // Usage limits (snapshot from plan, avoids join on every request)
  max_products    Int @default(500)
  max_customers   Int @default(999999)
  try_on_credits  Int @default(0)
  max_staff_seats Int @default(3) // 3 free, additional seats ₹199/mo (PRO-REQUIREMENTS.md §6)

  // Razorpay
  razorpay_customer_id     String?
  razorpay_subscription_id String?

  // Onboarding
  onboarding_completed Boolean @default(false)
  onboarding_step      Int     @default(0)

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  // Relations
  products              Product[]
  customers             Customer[]
  collections           Collection[]
  staff                 Staff[]
  store_sections        StoreSection[]
  subscriptions         Subscription[]
  try_on_usage          TryOnUsageLog[]
  size_charts           SizeChart[]
  limit_overrides       RetailerLimitOverride[]
  usage_counters        UsageCounter[]
  quota_addon_purchases QuotaAddonPurchase[]
  territory             Territory?              @relation(fields: [territory_id], references: [id])
  onboarded_by          TeamMember?             @relation("OnboardedRetailers", fields: [onboarded_by_id], references: [id])
  support_owner         TeamMember?             @relation("SupportedRetailers", fields: [support_owner_id], references: [id])
  support_tickets       SupportTicket[]

  @@index([phone])
  @@index([city])
  @@index([territory_id])
  @@map("retailers")
}

// ─── STORE STRUCTURE ─────────────────────────────────────────────

model StoreSection {
  id          String  @id @default(cuid())
  retailer_id String
  name        String
  type        String  @default("rack") // rack | shelf | section | floor | box
  parent_id   String?
  sort_order  Int     @default(0)

  retailer Retailer       @relation(fields: [retailer_id], references: [id])
  parent   StoreSection?  @relation("SectionTree", fields: [parent_id], references: [id])
  children StoreSection[] @relation("SectionTree")
  products Product[]

  @@index([retailer_id])
  @@map("store_sections")
}

// ─── PRODUCTS ────────────────────────────────────────────────────

model Product {
  id          String        @id @default(cuid())
  retailer_id String
  name        String?
  price_min   Int? // stored as paise (₹1500 = 150000)
  price_max   Int?
  mrp         Int?
  status      ProductStatus @default(AVAILABLE)

  // AI-generated (editable)
  category         String?
  product_type     String?
  primary_color    String?
  secondary_colors String[]
  fabric_estimate  String?
  pattern          String?
  embellishments   String[]
  neck_style       String?
  sleeve_type      String?
  occasions        String[]
  search_tags      String[]

  // Flexible extra metadata
  metadata Json?
  notes    String?

  // Physical location
  section_id     String?
  location_notes String?

  // Tagging state
  ai_tagged    Boolean @default(false)
  ai_tag_error String?

  // 360-degree spin view state — null until a spin video is uploaded.
  // 'processing' | 'ready' | 'failed', set by the frame-extraction job.
  spin_status String?
  spin_error  String?

  // F-011: retailer-picked backdrop from the admin-curated library, applied
  // by cleanupProductPhoto() in place of the default white flatten. Null =
  // white (unchanged default behavior).
  background_image_id String?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  retailer         Retailer              @relation(fields: [retailer_id], references: [id])
  section          StoreSection?         @relation(fields: [section_id], references: [id])
  background_image BackgroundImage?      @relation(fields: [background_image_id], references: [id], onDelete: SetNull)
  photos           ProductPhoto[]
  spin_frames      ProductSpinFrame[]
  variants         ProductVariant[]
  embedding        ProductEmbedding?
  collection_items CollectionProduct[]
  interactions     CustomerInteraction[]

  @@index([retailer_id])
  @@index([retailer_id, status])
  @@index([retailer_id, category])
  @@index([retailer_id, deleted_at])
  @@map("products")
}

model ProductPhoto {
  id          String @id @default(cuid())
  product_id  String
  retailer_id String

  url        String
  r2_key     String
  is_primary Boolean @default(false)
  width      Int?
  height     Int?
  size_bytes Int?

  ai_tagged       Boolean @default(false)
  ai_raw_response Json?

  // Retailer-tagged piece role for multi-piece outfits (kameez+salwar, kurta+
  // pajama, choli+skirt) — 'upper' | 'lower' | null. Drives try-on chaining
  // in packages/ai/src/tryon.ts; see PRO-REQUIREMENTS.md F-102.
  piece_type String?

  // F-001d bulk onboarding: 64-bit aHash hex string, used to flag likely
  // duplicate re-shoots of the same garment across rack photos/imports.
  // See packages/ai/src/phash.ts.
  phash String?

  sort_order Int      @default(0)
  created_at DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_photos")
}

model ProductSpinFrame {
  id          String @id @default(cuid())
  product_id  String
  retailer_id String

  url         String
  r2_key      String
  frame_index Int

  created_at DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_spin_frames")
}

model ProductVariant {
  id          String @id @default(cuid())
  product_id  String
  retailer_id String

  color          String
  photo_url      String?
  r2_key         String? // R2 storage key, used for generating presigned GET URLs
  ai_preview_url String?
  is_ai_preview  Boolean       @default(false)
  status         ProductStatus @default(AVAILABLE)
  price_override Int?

  created_at DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_variants")
}

model ProductEmbedding {
  id          String @id @default(cuid())
  product_id  String @unique
  retailer_id String

  // pgvector — 1536-dim for OpenAI text-embedding-3-small
  embedding Unsupported("vector(1536)")?

  input_hash    String // SHA-256 of product text fields
  model_version String @default("text-embedding-3-small")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([retailer_id])
  @@map("product_embeddings")
}

// ─── CUSTOMERS ───────────────────────────────────────────────────

model Customer {
  id          String @id @default(cuid())
  retailer_id String

  name       String
  phone      String
  phone_hash String?
  email      String?
  gender     Gender?

  // Consent to be contacted — required when captured via the public QR
  // profile gate, unset for retailer-manual-entry customers.
  consent_given Boolean   @default(false)
  consent_at    DateTime?

  // Full address
  address_line1 String?
  address_line2 String?
  city          String?
  state         String?
  pincode       String?

  // Explicit preferences (retailer-entered)
  pref_colors    String[]
  pref_styles    String[]
  pref_fabrics   String[]
  pref_occasions String[]
  budget_min     Int? // paise
  budget_max     Int? // paise

  notes String?

  last_visit_at   DateTime?
  total_purchases Int       @default(0)
  total_spent     Int       @default(0) // paise

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  retailer         Retailer              @relation(fields: [retailer_id], references: [id])
  fashion_dna      CustomerFashionDNA?
  interactions     CustomerInteraction[]
  collections_sent Collection[]          @relation("CustomerCollections")
  measurements     CustomerMeasurement[]

  @@unique([retailer_id, phone])
  @@index([retailer_id])
  @@index([retailer_id, phone_hash])
  @@map("customers")
}

// ─── CUSTOMER MEASUREMENTS (Phase 1 — VTO fit input) ────────────

model CustomerMeasurement {
  id          String @id @default(cuid())
  customer_id String
  retailer_id String

  source MeasurementSource

  height_cm Float
  bust_cm   Float?
  waist_cm  Float?
  hip_cm    Float?

  // Lower body (pant/salwar fit)
  pant_waist_cm Float?
  pant_hip_cm   Float?
  inseam_cm     Float?

  // Photo path only — originals deleted right after landmark extraction
  front_photo_r2_key  String?
  back_photo_r2_key   String?
  photo_deleted_at    DateTime?
  pose_landmarks_json Json?
  confidence_score    Float?

  // Customer consent to capture/use these photos — required for the PHOTO
  // source path, always false for MANUAL (no photo taken).
  consent_given Boolean   @default(false)
  consent_at    DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  customer    Customer   @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  try_on_jobs TryOnJob[]

  @@index([customer_id])
  @@index([retailer_id])
  @@map("customer_measurements")
}

model CustomerFashionDNA {
  id          String @id @default(cuid())
  customer_id String @unique
  retailer_id String

  // pgvector — learned preference vector
  preference_vector Unsupported("vector(1536)")?

  color_affinities    Json @default("{}")
  style_affinities    Json @default("{}")
  fabric_affinities   Json @default("{}")
  occasion_affinities Json @default("{}")
  budget_range        Json @default("{}")

  interaction_count Int      @default(0)
  confidence_score  Float    @default(0.0)
  last_updated_at   DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([retailer_id])
  @@map("customer_fashion_dna")
}

model CustomerInteraction {
  id            String  @id @default(cuid())
  customer_id   String
  retailer_id   String
  product_id    String?
  collection_id String?

  type     String // view | favorite | enquiry | purchase | try_on
  metadata Json?

  created_at DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [product_id], references: [id])

  @@index([customer_id])
  @@index([retailer_id, created_at])
  @@map("customer_interactions")
}

// ─── COLLECTIONS ─────────────────────────────────────────────────

model Collection {
  id          String  @id @default(cuid())
  retailer_id String
  customer_id String?

  title       String
  description String?
  slug        String           @unique
  status      CollectionStatus @default(ACTIVE)
  expires_at  DateTime?

  // Cached analytics
  view_count          Int @default(0)
  unique_viewer_count Int @default(0)
  enquiry_count       Int @default(0)
  favorite_count      Int @default(0)

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  retailer  Retailer            @relation(fields: [retailer_id], references: [id])
  customer  Customer?           @relation("CustomerCollections", fields: [customer_id], references: [id])
  products  CollectionProduct[]
  views     CollectionView[]
  enquiries CollectionEnquiry[]

  @@index([retailer_id])
  @@index([slug])
  @@index([retailer_id, status])
  @@map("collections")
}

model CollectionProduct {
  id            String @id @default(cuid())
  collection_id String
  product_id    String
  sort_order    Int    @default(0)

  collection Collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [product_id], references: [id])

  @@unique([collection_id, product_id])
  @@index([collection_id])
  @@map("collection_products")
}

model CollectionView {
  id            String @id @default(cuid())
  collection_id String
  retailer_id   String

  viewer_token String?
  ip_hash      String?
  user_agent   String?

  created_at DateTime @default(now())

  collection Collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)

  @@index([collection_id])
  @@index([collection_id, viewer_token])
  @@map("collection_views")
}

model CollectionEnquiry {
  id            String @id @default(cuid())
  collection_id String
  retailer_id   String

  product_id     String?
  message        String?
  customer_name  String?
  customer_phone String?
  status         EnquiryStatus @default(NEW)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  collection Collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)

  @@index([collection_id])
  @@index([retailer_id, status])
  @@map("collection_enquiries")
}

// ─── STAFF ───────────────────────────────────────────────────────

model Staff {
  id           String  @id @default(cuid())
  retailer_id  String
  auth_user_id String? @unique

  name      String
  phone     String
  role      String  @default("salesperson") // owner | manager | salesperson
  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  retailer Retailer @relation(fields: [retailer_id], references: [id])

  @@index([retailer_id])
  @@map("staff")
}

// ─── INTERNAL TEAM (Kanchuki admin/marketing/support) ─────────────
// See docs/PRO-REQUIREMENTS.md Section 10. Separate from retailer-side
// Staff above — these are Kanchuki's own employees.

model TeamMember {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password_hash String
  role          TeamRole
  is_active     Boolean  @default(true)
  max_retailers Int? // soft cap; dashboard flags when exceeded, never blocks onboarding

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  territories         TeamMemberTerritory[]
  onboarded_retailers Retailer[]            @relation("OnboardedRetailers")
  supported_retailers Retailer[]            @relation("SupportedRetailers")
  assigned_tickets    SupportTicket[]

  @@index([email])
  @@map("team_members")
}

model Territory {
  id        String         @id @default(cuid())
  name      String
  level     TerritoryLevel
  parent_id String? // self-reference: ZONE -> CITY -> STATE
  pincodes  String[] // only meaningful at ZONE level

  parent    Territory?            @relation("TerritoryHierarchy", fields: [parent_id], references: [id])
  children  Territory[]           @relation("TerritoryHierarchy")
  staff     TeamMemberTerritory[]
  retailers Retailer[]

  @@index([parent_id])
  @@map("territories")
}

model TeamMemberTerritory {
  id             String   @id @default(cuid())
  team_member_id String
  territory_id   String
  assigned_at    DateTime @default(now())

  team_member TeamMember @relation(fields: [team_member_id], references: [id])
  territory   Territory  @relation(fields: [territory_id], references: [id])

  @@unique([team_member_id, territory_id])
  @@index([territory_id])
  @@map("team_member_territories")
}

model SupportTicket {
  id              String       @id @default(cuid())
  retailer_id     String
  requires_visit  Boolean      @default(false)
  region_scope_id String? // Territory.id this ticket is poolable within, when not visit-bound
  assigned_to_id  String? // TeamMember.id, nullable until picked up
  status          TicketStatus @default(OPEN)
  note            String?

  created_at  DateTime  @default(now())
  resolved_at DateTime?

  retailer    Retailer    @relation(fields: [retailer_id], references: [id])
  assigned_to TeamMember? @relation(fields: [assigned_to_id], references: [id])

  @@index([retailer_id])
  @@index([status])
  @@map("support_tickets")
}

// ─── SUBSCRIPTIONS ───────────────────────────────────────────────

model Subscription {
  id             String             @id @default(cuid())
  retailer_id    String
  plan           SubscriptionPlan
  status         SubscriptionStatus
  billing_period String             @default("monthly")
  amount_inr     Int // paise

  razorpay_subscription_id String? @unique
  razorpay_plan_id         String?

  current_period_start DateTime
  current_period_end   DateTime
  cancelled_at         DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  retailer Retailer              @relation(fields: [retailer_id], references: [id])
  payments SubscriptionPayment[]

  @@index([retailer_id])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id              String @id @default(cuid())
  subscription_id String
  retailer_id     String

  amount_inr          Int
  currency            String  @default("INR")
  status              String // success | failed | refunded
  razorpay_payment_id String? @unique
  razorpay_order_id   String?

  amount_excluding_gst Int?
  gst_amount           Int?
  gst_invoice_number   String?

  paid_at    DateTime?
  created_at DateTime  @default(now())

  subscription Subscription @relation(fields: [subscription_id], references: [id])

  @@index([retailer_id])
  @@map("subscription_payments")
}

// ─── VIRTUAL TRY-ON (Phase 1 ready) ─────────────────────────────

model TryOnJob {
  id          String @id @default(cuid())
  retailer_id String

  product_id            String
  measurement_id        String? // measurement snapshot used to scale/fit garment
  customer_photo_r2_key String
  result_r2_key         String?
  result_url            String?

  status        TryOnStatus @default(QUEUED)
  error_message String?

  api_provider String
  api_job_id   String?
  api_cost_usd Float?

  queued_at    DateTime  @default(now())
  started_at   DateTime?
  completed_at DateTime?

  customer_photo_deleted_at DateTime?
  result_expires_at         DateTime?

  // Customer opted in (explicit checkbox, separate from the required
  // processing consent) to let Kanchuki keep a copy of this try-on's photos
  // for model training. Default false — training storage never happens
  // silently. See TrainingPhotoConsent and docs/SECURITY.md §3b.
  consent_to_training Boolean @default(false)

  measurement CustomerMeasurement? @relation(fields: [measurement_id], references: [id])

  @@index([retailer_id])
  @@index([status])
  @@map("try_on_jobs")
}

// ─── TRAINING DATA (consent-gated, admin-only — NOT retailer-visible) ──
// Deliberately has no retailer_id and no retailer-facing RLS policy (see
// migration 008). Populated only when TryOnJob.consent_to_training was true
// at job-submission time. Distinct from TryOnJob's own photo lifecycle —
// TryOnJob's customer_photo_r2_key still gets deleted per the existing
// privacy promise; this is a separate, deliberately-retained copy.
model TrainingPhotoConsent {
  id            String @id @default(cuid())
  try_on_job_id String @unique

  customer_photo_r2_key String
  garment_photo_r2_key  String
  result_r2_key         String?

  consent_version String // matches the consent copy text shown at capture time
  source          TryOnSource

  // Random token returned to the customer via the try-on result screen.
  // The customer presents this token at /consent/revoke to prove ownership
  // and request deletion of their training-data copy — no login needed.
  // See docs/PRO-REQUIREMENTS.md F-102d and docs/SECURITY.md §3b.
  revocation_token String @unique @default(cuid())

  consented_at DateTime @default(now())

  @@map("training_photo_consents")
}

// ─── TRY-ON USAGE LOGS ───────────────────────────────────────────
// Tracks per-retailer GPU usage for billing/quotas.
// This is the single source of truth for try-on cost tracking.

enum TryOnSource {
  IN_STORE // Shopkeeper-initiated from the mobile app
  REMOTE // Customer-initiated from the web collection page
}

model TryOnUsageLog {
  id            String @id @default(cuid())
  retailer_id   String
  try_on_job_id String
  product_id    String

  cost_usd Float // Estimated GPU cost (CatVTON ~$0.005)
  source   TryOnSource // How the try-on was triggered

  created_at   DateTime  @default(now())
  completed_at DateTime?

  retailer Retailer @relation(fields: [retailer_id], references: [id])

  @@index([retailer_id])
  @@index([retailer_id, created_at])
  @@index([created_at])
  @@map("try_on_usage_logs")
}

// ─── QUOTA & LIMITS (F-010) ──────────────────────────────────────
// Admin-configurable limits per plan/resource + per-retailer overrides,
// a rolling usage counter checked before every metered action, and
// self-serve overage purchases. See docs/PRO-REQUIREMENTS.md F-010.

// F-011: admin-curated backdrop library. Retailers select one for their
// product photo/spin; cleanupProductPhoto() composites the bg-stripped
// cutout onto it instead of the default white flatten.
model BackgroundImage {
  id                  String   @id @default(cuid())
  name                String
  image_url           String
  thumbnail_url       String?
  is_active           Boolean  @default(true)
  created_by_admin_id String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products Product[]

  @@map("background_images")
}

model PlanLimit {
  id               String            @id @default(cuid())
  plan             SubscriptionPlan
  resource_type    QuotaResourceType
  limit_per_period Int // -1 = unlimited
  period           QuotaPeriod       @default(MONTH)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([plan, resource_type])
  @@map("plan_limits")
}

model RetailerLimitOverride {
  id               String            @id @default(cuid())
  retailer_id      String
  resource_type    QuotaResourceType
  limit_per_period Int // -1 = unlimited
  period           QuotaPeriod       @default(MONTH)
  reason           String? // why admin granted a bespoke limit

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  retailer Retailer @relation(fields: [retailer_id], references: [id], onDelete: Cascade)

  @@unique([retailer_id, resource_type])
  @@index([retailer_id])
  @@map("retailer_limit_overrides")
}

model UsageCounter {
  id            String            @id @default(cuid())
  retailer_id   String
  resource_type QuotaResourceType
  period_start  DateTime // truncated to period boundary (day/month start)
  count         Int               @default(0)

  updated_at DateTime @updatedAt

  retailer Retailer @relation(fields: [retailer_id], references: [id], onDelete: Cascade)

  @@unique([retailer_id, resource_type, period_start])
  @@index([retailer_id])
  @@map("usage_counters")
}

model QuotaAddonPurchase {
  id            String            @id @default(cuid())
  retailer_id   String
  resource_type QuotaResourceType
  quantity      Int // extra units purchased, credited to the current UsageCounter period

  amount_inr Int // paise
  status     QuotaAddonStatus @default(PENDING)

  razorpay_order_id   String?
  razorpay_payment_id String?

  gst_amount         Int?
  gst_invoice_number String?

  created_at   DateTime  @default(now())
  completed_at DateTime?

  retailer Retailer @relation(fields: [retailer_id], references: [id])

  @@index([retailer_id])
  @@index([retailer_id, created_at])
  @@map("quota_addon_purchases")
}

// ─── SIZE CHARTS (F-102c — size recommendation, no GPU cost) ────

model SizeChart {
  id          String            @id @default(cuid())
  retailer_id String
  category    SizeChartCategory
  name        String            @default("Default")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  retailer Retailer       @relation(fields: [retailer_id], references: [id], onDelete: Cascade)
  rows     SizeChartRow[]

  @@unique([retailer_id, category])
  @@index([retailer_id])
  @@map("size_charts")
}

model SizeChartRow {
  id            String @id @default(cuid())
  size_chart_id String

  size_label String // S, M, L, XL, XXL, 3XL ... 10XL
  sort_order Int // S=1, M=2, ... — lets lookup walk to the nearest size

  bust_min_cm   Float?
  bust_max_cm   Float?
  waist_min_cm  Float?
  waist_max_cm  Float?
  hip_min_cm    Float?
  hip_max_cm    Float?
  length_min_cm Float? // inseam/length, LOWER category only
  length_max_cm Float?

  size_chart SizeChart @relation(fields: [size_chart_id], references: [id], onDelete: Cascade)

  @@unique([size_chart_id, size_label])
  @@index([size_chart_id])
  @@map("size_chart_rows")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────

model AuditLog {
  id String @id @default(cuid())

  actor_id      String?
  actor_type    String?
  action        String
  resource_type String
  resource_id   String?
  metadata      Json?
  ip_address    String?

  created_at DateTime @default(now())

  @@index([actor_id])
  @@index([resource_type, resource_id])
  @@index([created_at])
  @@map("audit_logs")
}

// ─── INTEGRATION SETTINGS ──────────────────────────────────────────
// Admin-managed, encrypted third-party credentials (F-012). Replaces the
// corresponding .env var when a row is active — see @kanchuki/db/secrets
// getSecret(). Bootstrap secrets that resolve this table (DATABASE_URL,
// ENCRYPTION_MASTER_KEY, SUPABASE_JWT_SECRET, TEAM_JWT_SECRET) can never
// live here — chicken-and-egg, they stay env-only.

enum IntegrationCategory {
  AI
  PAYMENT
  STORAGE
  WHATSAPP
}

model IntegrationSetting {
  id String @id @default(cuid())

  key_name String              @unique // matches the .env var name it overrides, e.g. "RAZORPAY_KEY_SECRET"
  category IntegrationCategory
  label    String // human label shown in admin UI, e.g. "Razorpay Key Secret"

  encrypted_value String // AES-256-GCM: base64(iv).base64(authTag).base64(ciphertext)
  masked_preview  String // e.g. "sk_live_••••wxyz" — safe to return from the API, never the real value

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([category])
  @@map("integration_settings")
}
