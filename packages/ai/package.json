{
  "name": "@kanchuki/ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tagger": {
      "types": "./src/tagger.ts",
      "import": "./dist/tagger.js",
      "default": "./dist/tagger.js"
    },
    "./embedder": {
      "types": "./src/embedder.ts",
      "import": "./dist/embedder.js",
      "default": "./dist/embedder.js"
    },
    "./r2": {
      "types": "./src/r2.ts",
      "import": "./dist/r2.js",
      "default": "./dist/r2.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-s3": "^3.620.0",
    "@aws-sdk/s3-request-presigner": "^3.620.0",
    "@imgly/background-removal-node": "^1.4.5",
    "@kanchuki/shared": "workspace:*",
    "openai": "^4.52.0",
    "sharp": "^0.33.5",
    "pdfjs-dist": "^4.8.69"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sharp": "^0.32.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
