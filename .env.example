# ─── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/postgres"
# Transaction pooler for runtime (Fastify API)
DATABASE_URL_POOLER="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# ─── Supabase Auth ──────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""   # NEVER commit actual value

# ─── Redis (Upstash) ────────────────────────────────────────────
REDIS_URL="redis://default:password@host:port"

# ─── Cloudflare R2 ──────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""      # NEVER commit actual value
R2_BUCKET_NAME="kanchuki-dev"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─── AI APIs ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""  # NEVER commit actual value
OPENAI_API_KEY=""     # NEVER commit actual value

# Virtual Try-On (CatVTON self-hosted — primary, ~$0.005/try-on)
# Deploy separate GPU service: see services/tryon/README.md
# Omit this to fall back to FASHN API
# Set to your RunPod endpoint URL (e.g. https://api.runpod.ai/v2/{endpoint_id})
# or your self-hosted CatVTON server (e.g. http://localhost:8000)
CATVTON_API_URL="https://api.runpod.ai/v2/your-endpoint-id"

# FASHN API (cloud fallback, ~$0.075/try-on)
FASHN_API_KEY=""      # NEVER commit actual value — https://fashn.ai/api-keys

# ─── Payments ───────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="xxx"       # NEVER commit actual value
RAZORPAY_WEBHOOK_SECRET="xxx"   # NEVER commit actual value

# ─── App Config ─────────────────────────────────────────────────
NODE_ENV="development"
PORT="3001"
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
JWT_SECRET="local-dev-secret-change-in-production"

# ─── Monitoring (Optional in dev) ───────────────────────────────
SENTRY_DSN=""
AXIOM_TOKEN=""
AXIOM_DATASET="kanchuki-logs"
