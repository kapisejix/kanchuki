# ─── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/postgres"
# Transaction pooler for runtime (Fastify API)
DATABASE_URL_POOLER="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# ─── Supabase Auth ──────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY=""
# NEVER commit actual value — must be the service_role key, NOT the anon key
SUPABASE_SERVICE_KEY=""
# Settings > API > JWT Secret. Used to verify auth tokens locally (HS256)
# instead of round-tripping to Supabase's Auth API on every request.
SUPABASE_JWT_SECRET=""      # NEVER commit actual value

# ─── Redis (Upstash) ────────────────────────────────────────────
REDIS_URL="redis://default:password@host:port"

# ─── Cloudflare R2 ──────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""      # NEVER commit actual value
R2_BUCKET_NAME="kanchuki-dev"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─── AI APIs ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""  # NEVER commit actual value (for Claude Vision AI tagging)
OPENAI_API_KEY=""     # NEVER commit actual value (for embeddings)

# Virtual Try-On (CatVTON self-hosted, ~$0.005/try-on)
# Deploy separate GPU service: see services/tryon/README.md
# Set to your RunPod endpoint URL (e.g. https://api.runpod.ai/v2/{endpoint_id})
# or your self-hosted CatVTON server (e.g. http://localhost:8000)
CATVTON_API_URL="https://api.runpod.ai/v2/your-endpoint-id"
# RunPod account API key — required only when CATVTON_API_URL is a RunPod endpoint
RUNPOD_API_KEY=""      # NEVER commit actual value — https://www.runpod.io/console/user/settings

# ─── Payments (Razorpay) ────────────────────────────────────────
# Live keys — set real values in production
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="xxx"       # NEVER commit actual value
RAZORPAY_WEBHOOK_SECRET="xxx"   # NEVER commit actual value
# Razorpay plan IDs — create plans in Razorpay dashboard → Plans, then map here
# Needed for POST /billing/subscription to work
RAZORPAY_PLAN_STARTER_MONTHLY=""
RAZORPAY_PLAN_STARTER_ANNUAL=""
RAZORPAY_PLAN_GROWTH_MONTHLY=""
RAZORPAY_PLAN_GROWTH_ANNUAL=""
RAZORPAY_PLAN_PRO_MONTHLY=""
RAZORPAY_PLAN_PRO_ANNUAL=""

# ─── App Config ─────────────────────────────────────────────────
NODE_ENV="development"
PORT="3001"
# Used internally by the API server (self-reference) and by the web app API routes
API_URL="http://localhost:3001"
# Base URL for generated collection share links (e.g. /c/{slug})
WEB_URL="http://localhost:3000"
JWT_SECRET="local-dev-secret-change-in-production"
# Admin panel authentication — set a strong random string to protect /v1/admin/*
ADMIN_API_KEY=""

# On-demand ISR revalidation — shared secret between API and Web for cache purge
# Must match REVALIDATION_SECRET set in the Web app's Railway environment
# Used by PATCH /v1/products/:id/status to instantly update collection link pages
REVALIDATION_SECRET=""

# ─── Measurement Extraction (Python CV) ─────────────────────────
# Path to measurement_extractor.py script (default: scripts/measurement_extractor.py)
MEASUREMENT_SCRIPT_PATH=""
# Python binary to use (default: python3 on Unix, python on Windows)
PYTHON_BIN=""

# ─── Monitoring (Optional in dev) ───────────────────────────────
SENTRY_DSN=""
AXIOM_TOKEN=""
AXIOM_DATASET="kanchuki-logs"
