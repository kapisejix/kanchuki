# ─── pnpm Configuration ───────────────────────────────────────
#
# shamefully-hoist=true — hoists dependencies to root node_modules
# so Windows child_process.fork() can resolve paths without running
# into special characters (parentheses, +, @) in pnpm's virtual store.
# NativeWind's Metro plugin forks the tailwindcss CLI, and the store
# paths with () chars break on Windows (spawn UNKNOWN / ERROR_INVALID_NAME).

shamefully-hoist=true

# ─── Strict peer dependencies — warn instead of error ─────────
strict-peer-dependencies=false
