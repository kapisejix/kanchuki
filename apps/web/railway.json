{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm build --filter=@kanchuki/web",
    "watchPatterns": [
      "apps/web/**",
      "packages/shared/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @kanchuki/web start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30
  }
}
