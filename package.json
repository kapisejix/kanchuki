{
  "name": "kanchuki",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "test:e2e": "pnpm --filter @kanchuki/api exec tsx ../../scripts/e2e-test.ts",
    "test:e2e:skip-tryon": "pnpm --filter @kanchuki/api exec tsx ../../scripts/e2e-test.ts --skip-tryon",
    "test:e2e:seed": "pnpm --filter @kanchuki/api exec tsx ../../scripts/seed-credits.ts",
    "test:e2e:full": "bash scripts/run-e2e.sh",
    "db:generate": "turbo db:generate",
    "db:migrate": "pnpm --filter @kanchuki/db migrate:dev",
    "db:studio": "pnpm --filter @kanchuki/db studio",
    "db:push": "pnpm --filter @kanchuki/db db:push"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.10.5",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  }
}
