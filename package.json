{
  "name": "kanchuki",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "test:e2e": "pnpm --filter @kanchuki/api exec tsx ../../scripts/e2e-test.ts",
    "test:e2e:skip-tryon": "pnpm --filter @kanchuki/api exec tsx ../../scripts/e2e-test.ts --skip-tryon",
    "test:e2e:seed": "pnpm --filter @kanchuki/api exec tsx ../../scripts/seed-credits.ts",
    "test:e2e:full": "bash scripts/run-e2e.sh",
    "db:generate": "turbo db:generate",
    "db:migrate": "pnpm --filter @kanchuki/db migrate:dev",
    "db:studio": "pnpm --filter @kanchuki/db studio",
    "db:push": "pnpm --filter @kanchuki/db db:push"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.10.6",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1",
      "zod@<=3.22.2": ">=3.22.3",
      "esbuild@<=0.24.2": ">=0.25.0",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "fastify@<=5.7.2": ">=5.7.3",
      "fastify@<5.7.2": ">=5.7.2",
      "fastify@<=5.8.2": ">=5.8.3",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "vite@<=6.4.1": ">=6.4.2",
      "vite@<=6.4.2": ">=6.4.3",
      "uuid@<11.1.1": ">=11.1.1",
      "vitest@<3.2.6": ">=3.2.6",
      "postcss@<8.5.10": ">=8.5.10",
      "postcss@<=8.5.11": ">=8.5.12",
      "postcss@<=8.5.17": ">=8.5.18",
      "fast-uri@<=3.1.0": ">=3.1.1",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "fast-uri@>=3.0.0 <=3.1.3": ">=3.1.4",
      "fast-uri@>=2.3.1 <=2.4.2": ">=2.4.3",
      "fast-uri@>=2.3.1 <2.4.2": ">=2.4.2",
      "fast-uri@>=3.0.0 <3.1.3": ">=3.1.3",
      "brace-expansion@>=2.0.0 <2.1.2": ">=2.1.2",
      "brace-expansion@<1.1.16": ">=1.1.16",
      "sharp@<0.35.0": ">=0.35.0",
      "find-my-way@<=9.6.0": ">=9.7.0",
      "tar@<=7.5.20": ">=7.5.21"
    }
  }
}
